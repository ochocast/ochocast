# Stage 1: Build Storybook
FROM node:24-alpine@sha256:d1b3b4da11eefd5941e7f0b9cf17783fc99d9c6fc34884a665f40a06dbdfc94f AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build Storybook
RUN npm run build-storybook

# Stage 2: Serve with Nginx
FROM nginx:alpine@sha256:582c496ccf79d8aa6f8203a79d32aaf7ffd8b13362c60a701a2f9ac64886c93d

# Copy built Storybook assets from builder stage
# Storybook builds into storybook-static by default
COPY --from=builder /app/storybook-static /usr/share/nginx/html

# Copy custom nginx configuration for SPA fallback (if needed)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
