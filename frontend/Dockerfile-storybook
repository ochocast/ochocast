# Stage 1: Build Storybook
FROM node:18-alpine@sha256:8d6421d663b4c28fd3ebc498332f249011d118945588d0a35cb9bc4b8ca09d9e AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build Storybook
RUN npm run build-storybook

# Stage 2: Serve with Nginx
FROM nginx:alpine@sha256:5616878291a2eed594aee8db4dade5878cf7edcb475e59193904b198d9b830de

# Copy built Storybook assets from builder stage
# Storybook builds into storybook-static by default
COPY --from=builder /app/storybook-static /usr/share/nginx/html

# Copy custom nginx configuration for SPA fallback (if needed)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
