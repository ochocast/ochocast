{
  "version": "0.0.2",
  "scripts": {
    "postinstall": "concurrently \"cd backend && npm install\" \"cd frontend && npm install\"",
    "set-up:db": "cd database && docker compose up -d",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "cd frontend && npm run start",
    "lint": "cd backend && npm run lint && cd ../frontend && npm run lint",
    "format": "cd backend && npm run format && cd ../frontend && npm run format",
    "doc": "typedoc --out ./docs --entryPoints ./frontend/src --entryPoints ./backend/src --entryPointStrategy expand",
    "lint:fix": "cd backend && npm run lint:fix && cd ../frontend && npm run lint:fix",
    "prepare": "husky install",
    "docker:build": "export APP_VERSION=$(node -p \"require('./package.json').version\") && cd build-tools && docker compose -f docker-compose-build.yml build",
    "docker:push": "export APP_VERSION=$(node -p \"require('./package.json').version\") && cd build-tools && docker compose -f docker-compose-build.yml push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "name": "ochocast-webapp",
  "dependencies": {
    "@nestjs/common": "^10.4.19",
    "@nestjs/core": "^10.4.19",
    "concurrently": "^8.2.1",
    "date-fns": "^4.1.0",
    "react-datepicker": "^8.3.0",
    "react-player": "^2.13.0",
    "reflect-metadata": "^0.1.14",
    "typedoc": "^0.28.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.1",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/react": "^19.0.11",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^14.0.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "lint-staged": "^16.1.0",
    "prettier": "3.8.2",
    "ts-jest": "^29.3.2",
    "typeorm": "^0.3.20",
    "typescript-eslint": "^8.33.1"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "backend/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  }
}
