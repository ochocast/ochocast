{
  "name": "octocast-webapp",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "concurrently \"cd backend && npm install\" \"cd frontend && npm install\"",
    "set-up:db": "cd database && docker compose up -d",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "cd frontend && npm run start",
    "lint": "cd backend && npm run lint && cd ../frontend && npm run lint",
    "format": "cd backend && npm run format && cd ../frontend && npm run format",
    "doc": "typedoc --out ./docs --entryPoints ./frontend/src --entryPoints ./backend/src --entryPointStrategy expand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "concurrently": "^8.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react-player": "^2.13.0",
    "sharp": "^0.34.1",
    "typedoc": "^0.28.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/react": "^19.0.11",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "typeorm": "^0.3.20"
  }
}
