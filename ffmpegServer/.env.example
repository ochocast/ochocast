# Minio S3 Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
STOCK_MEDIA_BUCKET=media
STOCK_MINIATURE_BUCKET=miniature

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:admin@localhost:5672
VIDEO_QUEUE_NAME=video-transcoding-queue
VIDEO_RESULT_QUEUE_NAME=video-transcoding-results

# Worker Configuration
WORKER_ID=worker-1
WORKER_CONCURRENCY=1
FFMPEG_THREADS=2
LOG_LEVEL=info

# HLS Transcoding Configuration
HLS_RESOLUTIONS=360p,480p,720p
HLS_SEGMENT_DURATION=5

# Transcript API Configuration
TRANSCRIPT_PORT=8080
# Optional bearer token expected by OpenAI-compatible clients.
TRANSCRIPT_API_KEY=
# faster-whisper model loaded inside the transcript container.
LOCAL_WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD_FILTER=true
