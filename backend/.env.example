PG_PORT=5432
PG_HOST=localhost
PG_USERNAME=admin
PG_PASSWORD=admin
PG_DATABASE=ochocast-db
NODE_ENV=development

PORT=3001
WS_PORT=3001

AUTH_SERVER_URL=http://localhost:8080
AUTH_REALM=local-realm
AUTH_CLIENT_ID=nest-back
AUTH_SECRET=this-is-a-local-keycloak-secret

STOCK_SERVER_URL=http://localhost:9000
STOCK_CLIENT_ID=minioadmin
STOCK_SECRET=minioadmin
STOCK_MEDIA_BUCKET=media
STOCK_MINIATURE_BUCKET=miniature
STOCK_BRANDING_BUCKET=branding
STOCK_PROFILE_PICTURE_BUCKET=picture
STOCK_REGION=fr-par

RECORDING_VM_URL=http://localhost:8081

RABBITMQ_URL=amqp://admin:admin@localhost:5672
VIDEO_QUEUE_NAME=video-transcoding-queue
VIDEO_RESULT_QUEUE_NAME=video-transcoding-results

# Cron quotidien de transcription (ici : 02h00).
TRANSCRIPTION_CRON=0 2 * * *

# URL publique de l’API du worker créée par ops-architecture-lab.
# Récupérable avec :
# terraform -chdir=terraform/on-demand-machines output transcript_api_urls
TRANSCRIPTION_API_URL=http://WORKER_PUBLIC_IP:8080

# URLs des fonctions Scaleway qui démarrent et arrêtent le worker.
# Récupérables avec :
# terraform -chdir=serverless/worker-control/terraform output worker_start_url
# terraform -chdir=serverless/worker-control/terraform output worker_stop_url
WORKER_START_URL=https://WORKER_START_FUNCTION_URL
WORKER_STOP_URL=https://WORKER_STOP_FUNCTION_URL

# Même token que worker_control_token dans le terraform.tfvars du worker-control.
# Ne jamais mettre la vraie valeur dans Git.
WORKER_CONTROL_TOKEN=CHANGE_ME

# Le backend attend au maximum 60 × 5 secondes que le worker soit prêt.
WORKER_HEALTH_RETRIES=60
WORKER_HEALTH_DELAY_MS=5000

# Public base URL including the /api prefix, required behind a reverse proxy.
PUBLIC_API_URL=http://localhost:3001/api
