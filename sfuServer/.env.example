# ============================================================================
# SFU SERVER CONFIGURATION
# ============================================================================

# Server Port and Protocol
SERVER_PORT=8090
ENABLE_HTTPS=false

# HTTPS Configuration (only used if ENABLE_HTTPS=true)
# CERT_FILE=cert.pem
# KEY_FILE=key.pem
# HTTPS_PORT=443

# ============================================================================
# SFU MODE & CLUSTERING
# ============================================================================

# SFU Mode Configuration
# - "hybrid": Each server can be origin or edge depending on the room (recommended for clustering)
# - "standalone": Single SFU server (no clustering)
SFU_MODE=hybrid

# Server Identity (optional, auto-generated if not provided)
# Unique identifier for this SFU server in the cluster
# SFU_ID=sfu-1

# Server URL (required for hybrid/clustering mode)
# This is the public URL where this server can be reached by other SFUs and clients
# Auto-constructed from SERVER_PORT if not provided
# Example: http://sfu1.example.com:8090 or http://192.168.1.10:8090
SERVER_URL=http://localhost:8090

# Peer SFU URLs (comma-separated, for hybrid clustering mode)
# List of other SFU servers in the cluster to connect with
# Leave empty for single-server setup
# Example: http://sfu2.example.com:8091,http://sfu3.example.com:8092
PEER_SFU_URLS=

# Cascade Authentication Key (for secure cascade connections between SFUs)
# Use a strong, random key for production
CASCADE_AUTH_KEY=your-secure-cascade-key-here

# ============================================================================
# CONTROL PLANE & MONITORING
# ============================================================================

# Control Plane URL (optional, for metrics and centralized management)
# If provided, this SFU will send metrics to the control plane
# Example: http://control-plane.example.com:3000
# CONTROL_PLANE_URL=

# SFU Region (optional, for geographic/infrastructure organization)
# Used for labeling metrics and identifying SFU location
# Example: us-west-1, eu-central-1
# SFU_REGION=

# SFU Zone (optional, for zone-specific organization)
# Used for labeling metrics and identifying availability zones
# Example: zone-a, zone-b
# SFU_ZONE=

# ============================================================================
# ICE/NAT TRAVERSAL CONFIGURATION
# ============================================================================

# STUN Servers (comma-separated)
# Used for NAT traversal to discover public IP addresses
# Default: Google's public STUN servers
# Example: stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN Server (comma-separated for multiple servers)
# Required for NAT traversal in symmetric NAT / containerized environments
# Format: turn:host:port or turns:host:port (for TLS)
# TURN_SERVER=turn:turnserver.example.com:3478

# TURN Server Username
# TURN_USERNAME=username

# TURN Server Password
# TURN_PASSWORD=password

# Public IP (for NAT1To1 mapping)
# Use this if running in Docker/container with port mapping
# This IP will be advertised as the host candidate to WebRTC clients
# Example: 203.0.113.42 (your public IP)
# PUBLIC_IP=

# Enable ICE-TCP (for environments without UDP support)
# Set to "true" to enable TCP-based ICE candidates
# Useful for restrictive networks that block UDP
# ENABLE_ICE_TCP=false

# ICE Relay Only Mode
# Set to "true" to force all traffic through TURN server (relay-only)
# Useful for symmetric NAT environments or maximum privacy
# Only effective if TURN_SERVER is configured
# ICE_RELAY_ONLY=false

# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# Single Server (Standalone)
# SFU_MODE=standalone
# SERVER_PORT=8090
# ENABLE_HTTPS=false

# 3-Server Hybrid Cluster Example:

## Server 1 Configuration
# SFU_MODE=hybrid
# SERVER_PORT=8090
# SERVER_URL=http://192.168.1.10:8090
# PEER_SFU_URLS=http://192.168.1.11:8091,http://192.168.1.12:8092
# CASCADE_AUTH_KEY=my-secret-cascade-key
# SFU_REGION=us-west-1
# SFU_ZONE=zone-a

## Server 2 Configuration
# SFU_MODE=hybrid
# SERVER_PORT=8091
# SERVER_URL=http://192.168.1.11:8091
# PEER_SFU_URLS=http://192.168.1.10:8090,http://192.168.1.12:8092
# CASCADE_AUTH_KEY=my-secret-cascade-key
# SFU_REGION=us-west-1
# SFU_ZONE=zone-b

## Server 3 Configuration
# SFU_MODE=hybrid
# SERVER_PORT=8092
# SERVER_URL=http://192.168.1.12:8092
# PEER_SFU_URLS=http://192.168.1.10:8090,http://192.168.1.11:8091
# CASCADE_AUTH_KEY=my-secret-cascade-key
# SFU_REGION=us-west-1
# SFU_ZONE=zone-c
