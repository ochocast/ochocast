# Server Configuration
ENABLE_HTTPS=false
SERVER_PORT=8090

# HTTPS Configuration (only used if ENABLE_HTTPS=true)
CERT_FILE=cert.pem
KEY_FILE=key.pem
HTTPS_PORT=443

# SFU Mode Configuration
# - "hybrid": Each server can be origin or edge depending on the room (default, recommended)
# - "standalone": Single SFU server (no clustering)
SFU_MODE=hybrid

# Server URL (required for hybrid mode)
# This is the public URL where this server can be reached by other SFUs
# Example: http://sfu1.example.com:8090 or http://192.168.1.10:8090
SERVER_URL=http://localhost:8090

# Cascade Configuration (for multi-SFU setup)
# Authentication key for cascade connections (used by both origin and edge)
CASCADE_AUTH_KEY=your-secure-cascade-key-here

# Peer SFU URLs (comma-separated, for hybrid mode)
# List of other SFU servers in the cluster
# Example: http://sfu2.example.com:8091,http://sfu3.example.com:8092
PEER_SFU_URLS=

# Example configurations for a 3-server hybrid cluster:

## Server 1 (hybrid mode)
# SFU_MODE=hybrid
# SERVER_PORT=8090
# SERVER_URL=http://192.168.1.10:8090
# PEER_SFU_URLS=http://192.168.1.11:8091,http://192.168.1.12:8092
# CASCADE_AUTH_KEY=my-secret-cascade-key

## Server 2 (hybrid mode)
# SFU_MODE=hybrid
# SERVER_PORT=8091
# SERVER_URL=http://192.168.1.11:8091
# PEER_SFU_URLS=http://192.168.1.10:8090,http://192.168.1.12:8092
# CASCADE_AUTH_KEY=my-secret-cascade-key

## Server 3 (hybrid mode)
# SFU_MODE=hybrid
# SERVER_PORT=8092
# SERVER_URL=http://192.168.1.12:8092
# PEER_SFU_URLS=http://192.168.1.10:8090,http://192.168.1.11:8091
# CASCADE_AUTH_KEY=my-secret-cascade-key
